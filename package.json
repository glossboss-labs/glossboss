{
  "name": "glossboss",
  "private": true,
  "version": "1.2.0",
  "author": "Toine Rademacher and Bjorn Lammers",
  "license": "AGPL-3.0-only",
  "repository": "https://github.com/lammersbjorn/glossboss.git",
  "packageManager": "bun@1.3.8",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "sync:uncodixfy": "bun scripts/sync-uncodixfy.ts",
    "cf:deploy:check-env": "bun -e \"const required=['VITE_SUPABASE_URL','VITE_SUPABASE_ANON_KEY','VITE_TURNSTILE_SITE_KEY']; const env=typeof Bun!=='undefined'?Bun.env:process.env; const missing=required.filter((name)=>!(env[name]||'').trim()); if(missing.length){console.error('Missing required env vars for Cloudflare deploy: '+missing.join(', ')); process.exit(1);} \"",
    "cf:project:create": "bunx wrangler pages project create glossboss --production-branch main",
    "cf:deploy": "bun run cf:deploy:check-env && bun run build && bunx wrangler pages deploy dist --project-name glossboss --branch main --commit-dirty=true",
    "cf:deploy:preview": "bun run cf:deploy:check-env && bun run build && bunx wrangler pages deploy dist --project-name glossboss --branch preview --commit-dirty=true",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "preview": "vite preview",
    "i18n:extract": "bun scripts/extract-i18n.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "*.{json,md,css,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@mantine/core": "^8.3.16",
    "@mantine/hooks": "^8.3.16",
    "@supabase/supabase-js": "^2.98.0",
    "@tanstack/react-virtual": "^3.13.21",
    "lucide-react": "^0.577.0",
    "motion": "^12.35.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "supabase": "^2.77.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
