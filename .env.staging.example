# Copy to `.env.staging` when building against the hosted staging project.
# The staging frontend (dev.glossboss.ink) uses the staging Supabase project.
VITE_SUPABASE_URL=https://your-staging-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-staging-anon-key
VITE_TURNSTILE_SITE_KEY=your-cloudflare-turnstile-site-key
VITE_POSTHOG_KEY=your-posthog-project-key

# Polar.sh billing (server-side only — set as Supabase edge function secrets).
POLAR_ACCESS_TOKEN=your-polar-access-token
POLAR_WEBHOOK_SECRET=your-polar-webhook-secret
