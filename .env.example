# Copy to `.env.local` for local Supabase development.
VITE_SUPABASE_URL=http://127.0.0.1:54321
# Fill this from `bunx supabase status -o env` after `bun run supabase:start`.
VITE_SUPABASE_ANON_KEY=your-local-anon-key
VITE_TURNSTILE_SITE_KEY=your-cloudflare-turnstile-site-key

# Local development only (optional).
# If VITE_TURNSTILE_SITE_KEY is omitted in `bun run dev`, feedback falls back to a dev bypass token.
# VITE_FEEDBACK_BYPASS_TURNSTILE=true
